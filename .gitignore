app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android local machine config (SDK paths) — never commit
android/local.properties

# Android release signing credentials — never commit
android/key.properties

# Gradle caches
android/.gradle/

# gstack local files
.gstack/

# Design/plan HTML files generated during development
design-mockup-*.html
plan-*.html
.playwright-mcp/
icon-render.html
