<?xml version="1.0" encoding="utf-8"?>
<!--
  Flashcard widget layout — one word at a time, full detail.
  Cycles on every phone unlock via UnlockReceiver.
  Light mode variant.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:gravity="center"
    android:padding="16dp">

    <!-- Character — dominant, centre stage -->
    <TextView
        android:id="@+id/flashcard_character"
        android:layout_width="wrap_content"
        android:fontFamily="@font/nunito"
        android:layout_height="wrap_content"
        android:text="好"
        android:textSize="72sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:includeFontPadding="false"
        android:gravity="center" />

    <!-- Pinyin -->
    <TextView
        android:id="@+id/flashcard_pinyin"
        android:layout_width="wrap_content"
        android:fontFamily="@font/nunito"
        android:layout_height="wrap_content"
        android:text="hǎo"
        android:textSize="20sp"
        android:textColor="#666666"
        android:layout_marginTop="4dp"
        android:gravity="center" />

    <!-- Meaning -->
    <TextView
        android:id="@+id/flashcard_meaning"
        android:layout_width="wrap_content"
        android:fontFamily="@font/nunito"
        android:layout_height="wrap_content"
        android:text="good / well"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginTop="2dp"
        android:gravity="start" />

    <!-- Divider (TextView used — plain View not supported in RemoteViews) -->
    <TextView
        android:layout_width="40dp"
        android:fontFamily="@font/nunito"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp" />

    <!-- Example phrase -->
    <TextView
        android:id="@+id/flashcard_phrase"
        android:layout_width="wrap_content"
        android:fontFamily="@font/nunito"
        android:layout_height="wrap_content"
        android:text="你好  •  nǐ hǎo"
        android:textSize="13sp"
        android:textColor="#555555"
        android:gravity="center" />

    <!-- Phrase meaning -->
    <TextView
        android:id="@+id/flashcard_phrase_meaning"
        android:layout_width="wrap_content"
        android:fontFamily="@font/nunito"
        android:layout_height="wrap_content"
        android:text="hello / how are you"
        android:textSize="11sp"
        android:textColor="#999999"
        android:layout_marginTop="2dp"
        android:gravity="center" />

    <!-- Speaker button -->
    <TextView
        android:id="@+id/flashcard_speak_btn"
        android:layout_width="wrap_content"
        android:fontFamily="@font/nunito"
        android:layout_height="wrap_content"
        android:text="🔊"
        android:textSize="20sp"
        android:layout_marginTop="8dp"
        android:padding="4dp"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
