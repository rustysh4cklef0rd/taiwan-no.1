                android:layout_height="wrap_content"
                android:text="字"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#F5F5F5"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/pinyin_3"
                android:layout_width="wrap_content"
                android:fontFamily="@font/nunito"
                android:layout_height="wrap_content"
                android:text="zì"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/meaning_3"
                android:layout_width="match_parent"
                android:fontFamily="@font/nunito"
                android:layout_height="wrap_content"
                android:text="good"
                android:textSize="9sp"
                android:textColor="#777777"
                android:layout_marginTop="1dp"
                android:gravity="start"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cell_4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/word_cell_background_night"
            android:layout_margin="3dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/char_4"
                android:layout_width="wrap_content"
                android:fontFamily="@font/nunito"
                android:layout_height="wrap_content"
                android:text="字"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#F5F5F5"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/pinyin_4"
                android:layout_width="wrap_content"
                android:fontFamily="@font/nunito"
                android:layout_height="wrap_content"
                android:text="zì"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/meaning_4"
                android:layout_width="match_parent"
                android:fontFamily="@font/nunito"
                android:layout_height="wrap_content"
                android:text="good"
                android:textSize="9sp"
                android:textColor="#777777"
                android:layout_marginTop="1dp"
                android:gravity="start"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cell_5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/word_cell_background_night"
            android:layout_margin="3dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/char_5"
                android:layout_width="wrap_content"
                android:fontFamily="@font/nunito"
                android:layout_height="wrap_content"
                android:text="字"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#F5F5F5"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/pinyin_5"
                android:layout_width="wrap_content"
                android:fontFamily="@font/nunito"
                android:layout_height="wrap_content"
                android:text="zì"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/meaning_5"
                android:layout_width="match_parent"
                android:fontFamily="@font/nunito"
                android:layout_height="wrap_content"
                android:text="good"
                android:textSize="9sp"
                android:textColor="#777777"
                android:layout_marginTop="1dp"
                android:gravity="start"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
