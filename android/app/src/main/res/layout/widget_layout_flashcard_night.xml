<?xml version="1.0" encoding="utf-8"?>
<!-- Flashcard widget — dark mode variant -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background_night"
    android:gravity="center"
    android:padding="16dp">

    <TextView
        android:id="@+id/flashcard_character"
        android:layout_width="wrap_content"
        android:fontFamily="@font/nunito"
        android:layout_height="wrap_content"
        android:text="好"
        android:textSize="72sp"
        android:textStyle="bold"
        android:textColor="#E8E8E8"
        android:includeFontPadding="false"
        android:gravity="center" />

    <TextView
        android:id="@+id/flashcard_pinyin"
        android:layout_width="wrap_content"
        android:fontFamily="@font/nunito"
        android:layout_height="wrap_content"
        android:text="hǎo"
        android:textSize="20sp"
        android:textColor="#00F5FF"
        android:layout_marginTop="4dp"
        android:gravity="center" />

    <TextView
        android:id="@+id/flashcard_meaning"
        android:layout_width="wrap_content"
        android:fontFamily="@font/nunito"
        android:layout_height="wrap_content"
        android:text="good / well"
        android:textSize="14sp"
        android:textColor="#A0A0B0"
        android:layout_marginTop="2dp"
        android:gravity="center" />

    <TextView
        android:layout_width="40dp"
        android:fontFamily="@font/nunito"
        android:layout_height="1dp"
        android:background="#FF2E63"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/flashcard_phrase"
        android:layout_width="wrap_content"
        android:fontFamily="@font/nunito"
        android:layout_height="wrap_content"
        android:text="你好  •  nǐ hǎo"
        android:textSize="13sp"
        android:textColor="#E8E8E8"
        android:gravity="center" />

    <TextView
        android:id="@+id/flashcard_phrase_meaning"
        android:layout_width="wrap_content"
        android:fontFamily="@font/nunito"
        android:layout_height="wrap_content"
        android:text="hello / how are you"
        android:textSize="11sp"
        android:textColor="#A0A0B0"
        android:layout_marginTop="2dp"
        android:gravity="center" />

    <TextView
        android:id="@+id/flashcard_speak_btn"
        android:layout_width="wrap_content"
        android:fontFamily="@font/nunito"
        android:layout_height="wrap_content"
        android:text="🔊"
        android:textSize="20sp"
        android:layout_marginTop="8dp"
        android:padding="4dp"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
